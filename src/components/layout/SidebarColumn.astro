---
import { SidebarTOC } from "@components/features/toc";
import type { MarkdownHeading } from "astro";

import { widgetManager } from "@/utils/widget-manager";
import { buildComponentProps } from "@/utils/widget-renderer";

// 导入所有可能的组件
import Announcement from "../widgets/announcement/Announcement.astro";
import Calendar from "../widgets/calendar/Calendar.astro";
import CardTOC from "../widgets/card-toc/CardTOC.astro";
import Categories from "../widgets/categories/Categories.astro";
import MusicPlayer from "../widgets/music-player/MusicPlayer.svelte";
import MusicSidebarWidget from "../widgets/music-sidebar/MusicSidebarWidget.astro";
import Profile from "../widgets/profile/Profile.astro";
import SiteStats from "../widgets/site-stats/SiteStats.astro";
import Tags from "../widgets/tags/Tags.astro";

interface Props {
	side: "left" | "right";
	headings?: MarkdownHeading[];
	containerId?: string;
	stickyId?: string;
	rootClass?: string;
	topClass?: string;
	stickyClass?: string;
	showMobile?: boolean;
	showTablet?: boolean;
	showDesktop?: boolean;
}

const {
	side,
	headings,
	containerId,
	stickyId,
	rootClass = "w-full",
	topClass = "",
	stickyClass = "",
	showMobile = false,
	showTablet = true,
	showDesktop = true,
} = Astro.props;

// 获取各设备类型的组件配置
const mobileTopComponents = showMobile
	? widgetManager.getComponentsByPosition("top", side, "mobile")
	: [];
const mobileStickyComponents = showMobile
	? widgetManager.getComponentsByPosition("sticky", side, "mobile")
	: [];

const tabletTopComponents = showTablet
	? widgetManager.getComponentsByPosition("top", side, "tablet")
	: [];
const tabletStickyComponents = showTablet
	? widgetManager.getComponentsByPosition("sticky", side, "tablet")
	: [];

const desktopTopComponents = showDesktop
	? widgetManager.getComponentsByPosition("top", side, "desktop")
	: [];
const desktopStickyComponents = showDesktop
	? widgetManager.getComponentsByPosition("sticky", side, "desktop")
	: [];

// 辅助函数：根据组件类型渲染对应组件
type ComponentType = 
	| "profile" 
	| "announcement" 
	| "categories" 
	| "tags" 
	| "toc" 
	| "card-toc" 
	| "music-player" 
	| "music-sidebar" 
	| "site-stats" 
	| "calendar";

function getComponentType(type: string): ComponentType | null {
	const validTypes: ComponentType[] = [
		"profile", "announcement", "categories", "tags", "toc", 
		"card-toc", "music-player", "music-sidebar", "site-stats", "calendar"
	];
	return validTypes.includes(type as ComponentType) ? (type as ComponentType) : null;
}
---

<div id={containerId} class:list={[rootClass, "sidebar-column-root"]}>
	<div class:list={["flex flex-col w-full gap-4 mb-4", topClass]}>
		<!-- Mobile Top Components -->
		{
			showMobile && mobileTopComponents.length > 0 && (
				<div class="flex flex-col w-full gap-4 md:hidden">
					{mobileTopComponents.map((component, index) => {
						const props = buildComponentProps(component, index, headings);
						const type = getComponentType(component.type);
						if (!type) return null;
						
						return (
							<>
								{type === "profile" && <Profile {...props} />}
								{type === "announcement" && <Announcement {...props} />}
								{type === "categories" && <Categories {...props} />}
								{type === "tags" && <Tags {...props} />}
								{type === "toc" && <SidebarTOC {...props} />}
								{type === "card-toc" && <CardTOC {...props} />}
								{type === "music-player" && <MusicPlayer {...props} />}
								{type === "music-sidebar" && <MusicSidebarWidget {...props} />}
								{type === "site-stats" && <SiteStats {...props} />}
								{type === "calendar" && <Calendar {...props} />}
							</>
						);
					})}
				</div>
			)
		}

		<!-- Tablet Top Components -->
		{
			showTablet && tabletTopComponents.length > 0 && (
				<div class="sidebar-content hidden md:flex lg:hidden flex-col w-full gap-4">
					{tabletTopComponents.map((component, index) => {
						const props = buildComponentProps(component, index, headings);
						const type = getComponentType(component.type);
						if (!type) return null;
						
						return (
							<>
								{type === "profile" && <Profile {...props} />}
								{type === "announcement" && <Announcement {...props} />}
								{type === "categories" && <Categories {...props} />}
								{type === "tags" && <Tags {...props} />}
								{type === "toc" && <SidebarTOC {...props} />}
								{type === "card-toc" && <CardTOC {...props} />}
								{type === "music-player" && <MusicPlayer {...props} />}
								{type === "music-sidebar" && <MusicSidebarWidget {...props} />}
								{type === "site-stats" && <SiteStats {...props} />}
								{type === "calendar" && <Calendar {...props} />}
							</>
						);
					})}
				</div>
			)
		}

		<!-- Desktop Top Components -->
		{
			showDesktop && desktopTopComponents.length > 0 && (
				<div class="sidebar-content hidden lg:flex flex-col w-full gap-4">
					{desktopTopComponents.map((component, index) => {
						const props = buildComponentProps(component, index, headings);
						const type = getComponentType(component.type);
						if (!type) return null;
						
						return (
							<>
								{type === "profile" && <Profile {...props} />}
								{type === "announcement" && <Announcement {...props} />}
								{type === "categories" && <Categories {...props} />}
								{type === "tags" && <Tags {...props} />}
								{type === "toc" && <SidebarTOC {...props} />}
								{type === "card-toc" && <CardTOC {...props} />}
								{type === "music-player" && <MusicPlayer {...props} />}
								{type === "music-sidebar" && <MusicSidebarWidget {...props} />}
								{type === "site-stats" && <SiteStats {...props} />}
								{type === "calendar" && <Calendar {...props} />}
							</>
						);
					})}
				</div>
			)
		}
	</div>

	<div
		id={stickyId}
		class:list={[
			"transition-all duration-700 flex flex-col w-full gap-4 sticky top-4 sidebar-sticky-column",
			stickyClass,
		]}
	>
		<!-- Mobile Sticky Components -->
		{
			showMobile && mobileStickyComponents.length > 0 && (
				<div class="flex flex-col w-full gap-4 md:hidden">
					{mobileStickyComponents.map((component, index) => {
						const props = buildComponentProps(component, index, headings);
						const type = getComponentType(component.type);
						if (!type) return null;
						
						return (
							<>
								{type === "profile" && <Profile {...props} />}
								{type === "announcement" && <Announcement {...props} />}
								{type === "categories" && <Categories {...props} />}
								{type === "tags" && <Tags {...props} />}
								{type === "toc" && <SidebarTOC {...props} />}
								{type === "card-toc" && <CardTOC {...props} />}
								{type === "music-player" && <MusicPlayer {...props} />}
								{type === "music-sidebar" && <MusicSidebarWidget {...props} />}
								{type === "site-stats" && <SiteStats {...props} />}
								{type === "calendar" && <Calendar {...props} />}
							</>
						);
					})}
				</div>
			)
		}

		<!-- Tablet Sticky Components -->
		{
			showTablet && tabletStickyComponents.length > 0 && (
				<div class="sidebar-content hidden md:flex lg:hidden flex-col w-full gap-4">
					{tabletStickyComponents.map((component, index) => {
						const props = buildComponentProps(component, index, headings);
						const type = getComponentType(component.type);
						if (!type) return null;
						
						return (
							<>
								{type === "profile" && <Profile {...props} />}
								{type === "announcement" && <Announcement {...props} />}
								{type === "categories" && <Categories {...props} />}
								{type === "tags" && <Tags {...props} />}
								{type === "toc" && <SidebarTOC {...props} />}
								{type === "card-toc" && <CardTOC {...props} />}
								{type === "music-player" && <MusicPlayer {...props} />}
								{type === "music-sidebar" && <MusicSidebarWidget {...props} />}
								{type === "site-stats" && <SiteStats {...props} />}
								{type === "calendar" && <Calendar {...props} />}
							</>
						);
					})}
				</div>
			)
		}

		<!-- Desktop Sticky Components -->
		{
			showDesktop && desktopStickyComponents.length > 0 && (
				<div class="sidebar-content hidden lg:flex flex-col w-full gap-4">
					{desktopStickyComponents.map((component, index) => {
						const props = buildComponentProps(component, index, headings);
						const type = getComponentType(component.type);
						if (!type) return null;
						
						return (
							<>
								{type === "profile" && <Profile {...props} />}
								{type === "announcement" && <Announcement {...props} />}
								{type === "categories" && <Categories {...props} />}
								{type === "tags" && <Tags {...props} />}
								{type === "toc" && <SidebarTOC {...props} />}
								{type === "card-toc" && <CardTOC {...props} />}
								{type === "music-player" && <MusicPlayer {...props} />}
								{type === "music-sidebar" && <MusicSidebarWidget {...props} />}
								{type === "site-stats" && <SiteStats {...props} />}
								{type === "calendar" && <Calendar {...props} />}
							</>
						);
					})}
				</div>
			)
		}
	</div>
</div>
